# Artone Video Editor - Environment Configuration
# Copy this file to .env.local and configure values for your deployment

# ============================================
# Application Configuration (Required)
# ============================================

# Application origin URL (required for CORS, CSP, and security headers)
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

# API base URL (required for backend communication)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# Security Configuration (Recommended)
# ============================================

# CSRF secret key (generate with: openssl rand -base64 32)
CSRF_SECRET=your-csrf-secret-key-here

# Session secret key (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-key-here

# ============================================
# External Services (Optional)
# ============================================

# YouTube Data API v3 (for video search and metadata extraction)
# Get API key from: https://console.cloud.google.com/
# NEXT_PUBLIC_YOUTUBE_API_KEY=your-youtube-api-key-here

# OpenAI API (for Whisper transcription and GPT-4 analysis)
# Get API key from: https://platform.openai.com/
# NEXT_PUBLIC_OPENAI_API_KEY=your-openai-api-key-here

# AI Provider API Endpoints (only configure if using AI features)
# NEXT_PUBLIC_OPENAI_API_URL=https://api.openai.com/v1
# NEXT_PUBLIC_ANTHROPIC_API_URL=https://api.anthropic.com/v1
# NEXT_PUBLIC_GOOGLE_AI_API_URL=https://generativelanguage.googleapis.com/v1
# NEXT_PUBLIC_AZURE_API_URL=https://api.cognitive.microsofttranslator.com
# NEXT_PUBLIC_ELEVENLABS_API_URL=https://api.elevenlabs.io/v1

# TensorFlow.js Model Storage URL (only if using ML features)
# NEXT_PUBLIC_TFJS_MODEL_BASE_URL=https://your-model-storage.com

# ============================================
# Collaboration Features (Optional)
# ============================================

# WebSocket server for real-time collaboration
# NEXT_PUBLIC_COLLABORATION_SERVER=wss://your-collaboration-server.com

# ============================================
# Content Delivery (Optional)
# ============================================

# CDN origin for static assets
# NEXT_PUBLIC_ASSET_CDN=https://your-cdn.com

# ============================================
# Monitoring & Analytics (Optional)
# ============================================

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Google Analytics tracking ID
# NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================
# Support Configuration (Optional)
# ============================================

# Support email address for user inquiries
# NEXT_PUBLIC_SUPPORT_EMAIL=support@your-domain.com

# ============================================
# Billing & Payments (Optional)
# ============================================

# Enable subscription checkout experience
NEXT_PUBLIC_ENABLE_SUBSCRIPTIONS=false

# Stripe publishable key for client-side Checkout integration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Default Stripe price IDs for subscription plans (configure in Stripe dashboard)
NEXT_PUBLIC_STRIPE_PRICE_STANDARD_MONTHLY=price_standard_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_STANDARD_YEARLY=price_standard_yearly_id

# Optional Stripe price ID for lifetime license (one-time purchase)
NEXT_PUBLIC_STRIPE_PRICE_LIFETIME=price_lifetime_id

# Pricing guidance:
# - Monthly plan: $0.50/month (configure in Stripe as recurring price)
# - Yearly plan: $6.00/year (12 months × $0.50)
# - Lifetime plan: $3.00 one-time payment

# Stripe secret key for server-side API routes (never expose publicly)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Stripe webhook secret for validating subscription events
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# URL to return users to after managing billing in Stripe customer portal
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/account

# ============================================
# Development Settings
# ============================================

# Node environment (development, production, test)
NODE_ENV=development

# Enable debug logging (true/false)
# DEBUG=false

# ============================================
# Production Deployment Checklist
# ============================================

# Before deploying to production, ensure:
# 1. NEXT_PUBLIC_APP_ORIGIN is set to your production domain
# 2. NEXT_PUBLIC_API_URL points to your production API
# 3. CSRF_SECRET and SESSION_SECRET are cryptographically random
# 4. NODE_ENV is set to "production"
# 5. All optional services you use are configured
# 6. Run: npm audit and npm run security:check
# 7. Test CSP headers with: https://csp-evaluator.withgoogle.com/
# 8. Run: npm run build && npm run test:ci
