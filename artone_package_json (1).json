{
  "name": "artone-video-editor",
  "version": "1.0.0",
  "description": "Professional desktop video editor with multi-track timeline and real-time preview",
  "main": "main.js",
  "homepage": "./",
  "author": {
    "name": "Artone Team",
    "email": "team@artone.example.com"
  },
  "license": "MIT",
  "private": false,
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac", 
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "serve": "npx serve renderer -s -l 3000",
    "lint": "echo 'Linting will be added in future versions'",
    "test": "echo 'Tests will be added in future versions'"
  },
  "keywords": [
    "video-editor",
    "desktop-app", 
    "electron",
    "video-processing",
    "timeline",
    "multimedia",
    "real-time",
    "effects",
    "export"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/artone-video-editor.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/artone-video-editor/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {},
  "build": {
    "appId": "com.artone.video-editor",
    "productName": "Artone Video Editor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "Artone-Video-Editor-${version}-${arch}.${ext}",
      "publisherName": "Artone Team",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Artone Video Editor"
    },
    "portable": {
      "artifactName": "Artone-Video-Editor-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.video",
      "artifactName": "Artone-Video-Editor-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "Artone Video Editor ${version}",
      "artifactName": "Artone-Video-Editor-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "AudioVideo",
      "artifactName": "Artone-Video-Editor-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "yourusername",
      "repo": "artone-video-editor"
    }
  },
  "browserslist": [
    "Chrome >= 90"
  ]
}