{
  "name": "artone",
  "version": "3.0.0",
  "description": "Browser-native professional video editor — 100% local, serverless, offline-capable",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "analyze": "ANALYZE=true vite build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:design": "bash scripts/design-system-check.sh",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx}\" --ignore-path .gitignore",
    "bench": "tsx bench/runner.ts",
    "bench:baseline": "tsx bench/runner.ts --update-baseline",
    "sbom": "tsx security/generate.ts",
    "sbom:online": "tsx security/generate.ts --online",
    "build:a11y": "esbuild accessibility/bundle-entry.ts --bundle --format=iife --outfile=dist/a11y-bundle.js",
    "test:a11y": "npm run build:a11y && playwright test tests/a11y.spec.ts",
    "audit:full": "npm audit && npm run sbom && npm run bench && npm run test:a11y",
    "clean": "rm -rf dist node_modules/.vite",
    "prepare": "husky || true",
    "bench:watch": "tsx bench/runner.ts --watch",
    "syntax": "node scripts/syntax-check.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "lodash-es": "^4.17.21",
    "uuid": "^10.0.0",
    "date-fns": "^3.6.0",
    "tone": "^15.0.4",
    "standardized-audio-context": "^25.3.76",
    "@xenova/transformers": "^2.17.2",
    "idb": "^8.0.0",
    "comlink": "^4.4.1",
    "yjs": "^13.6.18",
    "y-webrtc": "^10.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/lodash-es": "^4.17.12",
    "@types/uuid": "^10.0.0",
    "@types/node": "^26.0.0",
    "@webgpu/types": "^0.1.45",
    "tsx": "^4.19.0",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "@vitejs/plugin-react": "^6.0.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "playwright": "^1.61.0",
    "@playwright/test": "^1.61.0",
    "eslint": "^10.5.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "@typescript-eslint/parser": "^8.2.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.8.4",
    "jsdom": "^29.1.1",
    "@types/jsdom": "^28.0.3",
    "husky": "^9.1.5",
    "lint-staged": "^17.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "Chrome >= 113",
    "Edge >= 113",
    "Safari >= 17"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shizukutanaka/artone"
  },
  "author": {
    "name": "Artone Contributors"
  },
  "license": "MIT",
  "keywords": [
    "video-editor",
    "webcodecs",
    "webgpu",
    "pwa",
    "browser",
    "artone"
  ],
  "homepage": "https://github.com/shizukutanaka/artone"
}
